// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//
// ======================================================
// ADMIN
// ======================================================
//

model AdminAccount {
  id                    String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                 String             @unique
  firstname             String
  lastname              String
  telephone             String
  password_hash         String
  status                String
  created_at            DateTime           @default(now())
  updated_at            DateTime           @updatedAt
  is_temporary_password Boolean            @default(false)
  roles                 AdminAccountRole[]

  @@map("admin_accounts")
}

model AdminRole {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique
  description String?
  created_at  DateTime @default(now())

  permissions AdminRolePermission[]
  accounts    AdminAccountRole[]

  @@map("admin_roles")
}

model AdminPermission {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String   @unique
  description String?
  created_at  DateTime @default(now())

  roles AdminRolePermission[]

  @@map("admin_permissions")
}

model AdminAccountRole {
  admin_account_id String @db.Uuid
  admin_role_id    String @db.Uuid

  admin_account AdminAccount @relation(fields: [admin_account_id], references: [id], onDelete: Cascade)
  admin_role    AdminRole    @relation(fields: [admin_role_id], references: [id], onDelete: Cascade)

  @@id([admin_account_id, admin_role_id])
  @@map("admin_account_roles")
}

model AdminRolePermission {
  admin_role_id       String @db.Uuid
  admin_permission_id String @db.Uuid

  admin_role       AdminRole       @relation(fields: [admin_role_id], references: [id], onDelete: Cascade)
  admin_permission AdminPermission @relation(fields: [admin_permission_id], references: [id], onDelete: Cascade)

  @@id([admin_role_id, admin_permission_id])
  @@map("admin_role_permissions")
}

//
// ======================================================
// CLIENT
// ======================================================
//

model ClientAccount {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String   @unique
  firstname     String
  lastname      String
  telephone     String
  password_hash String
  status        String
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  roles ClientAccountRole[]

  @@map("client_accounts")
}

model ClientRole {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique
  description String?
  created_at  DateTime @default(now())

  permissions ClientRolePermission[]
  accounts    ClientAccountRole[]

  @@map("client_roles")
}

model ClientPermission {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String   @unique
  description String?
  created_at  DateTime @default(now())

  roles ClientRolePermission[]

  @@map("client_permissions")
}

model ClientAccountRole {
  client_account_id String @db.Uuid
  client_role_id    String @db.Uuid

  client_account ClientAccount @relation(fields: [client_account_id], references: [id], onDelete: Cascade)
  client_role    ClientRole    @relation(fields: [client_role_id], references: [id], onDelete: Cascade)

  @@id([client_account_id, client_role_id])
  @@map("client_account_roles")
}

model ClientRolePermission {
  client_role_id       String @db.Uuid
  client_permission_id String @db.Uuid

  client_role       ClientRole       @relation(fields: [client_role_id], references: [id], onDelete: Cascade)
  client_permission ClientPermission @relation(fields: [client_permission_id], references: [id], onDelete: Cascade)

  @@id([client_role_id, client_permission_id])
  @@map("client_role_permissions")
}

//
// ======================================================
// API KEYS
// ======================================================
//

model ApiKey {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  application_id String
  key            String    @unique
  secret_hash    String
  status         String
  environment    String
  prefix         String
  created_at     DateTime  @default(now())
  revoked_at     DateTime?
  expires_at     DateTime?

  @@map("api_keys")
}

//
// ======================================================
// TOKENS
// ======================================================
//

model RefreshToken {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  account_id   String
  account_type String
  token        String    @unique
  expires_at   DateTime
  revoked_at   DateTime?
  created_at   DateTime  @default(now())

  @@map("refresh_tokens")
}

// Pour la gestion des mots de passe temporaires
model PasswordResetToken {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  account_id   String @db.Uuid
  account_type String // "admin" | "client"

  token_hash String    @unique
  expires_at DateTime
  used_at    DateTime?

  created_at DateTime @default(now())

  @@index([account_id])
  @@map("password_reset_tokens")
}

//
// ======================================================
// SECURITY LOGS
// ======================================================
//

model SecurityLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  account_id   String?
  account_type String?
  action       String
  ip_address   String?
  user_agent   String?
  created_at   DateTime @default(now())

  @@map("security_logs")
}
